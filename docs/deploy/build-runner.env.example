BUILD_COORDINATOR_URL=http://10.0.0.107:8090
BUILD_COORDINATOR_TOKEN=replace-with-oci-vault-secret
RUNNER_WORK_DIR=/var/lib/tinycloud-build-runner/work
RUNNER_POLL_INTERVAL=5s

# OCIR (Phase 1) — preferred
IMAGE_PREFIX=iad.ocir.io/idzghas4xwzv/tinycloud
BUILD_CACHE_REF=iad.ocir.io/idzghas4xwzv/tinycloud/cache:buildkit
# BUILD_PLATFORM=native  # default on ARM64 runner; use linux/arm64 for QEMU cross-build

# Legacy GHCR (fallback if IMAGE_PREFIX unset)
# GHCR_REGISTRY=ghcr.io
# GHCR_OWNER=sasirulk

GITHUB_TOKEN=replace-with-oci-vault-secret
